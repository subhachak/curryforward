# Copy this file to .env and fill in your own key.
# Chat customization and recipe generation won't work without it. All LLM
# assistant/generation/research endpoints are admin-only.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Set this to any secret string of your choosing. Enter the SAME value as
# the password on the app's /login page to unlock fork/save/review-approval.
# Anyone who doesn't log in gets browsing and moderated feedback only.
ADMIN_TOKEN=changeme

# Optional: separate key used to sign the admin session cookie. If unset,
# falls back to ADMIN_TOKEN (fine for local use) — set this explicitly if
# you want existing sessions to survive an ADMIN_TOKEN rotation.
SESSION_SECRET=

# Production hardening. Railway usually sets RAILWAY_ENVIRONMENT=production;
# APP_ENV=production also forces secure cookies and HSTS.
APP_ENV=development
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=600
RATE_LIMIT_LOGIN_PER_MINUTE=8
RATE_LIMIT_FEEDBACK_PER_MINUTE=20
RATE_LIMIT_LLM_PER_MINUTE=120
RATE_LIMIT_UPLOAD_PER_MINUTE=20

# Uvicorn's own proxy-header trust (see Dockerfile's CMD) — controls whether
# X-Forwarded-For is honored for rate-limiting/audit-log IPs, at the server
# level, before the app ever sees the request. Leave unset (trusts nothing,
# so the real TCP peer is always used) unless this container genuinely sits
# behind a reverse proxy that overwrites the header itself — e.g. set to
# Railway's edge address if deployed there. Never set to "*" on a directly
# reachable deployment: that would let any caller spoof their apparent IP
# and bypass every per-IP rate limit above.
# FORWARDED_ALLOW_IPS=

# Comma-separated list of frontend origins allowed to send credentialed
# requests (cookies). Defaults to the Next.js dev server if unset.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: override the local SQLite database path. Useful for tests,
# staging copies, running multiple local instances, or pointing production
# at a persistent disk/volume. On Railway with a volume mounted at /data:
# DATABASE_URL=sqlite:////data/curryforward.db
DATABASE_URL=sqlite:///./curryforward.db

# Optional: where uploaded recipe images are stored. Keep this on a persistent
# volume in production. On Railway with a volume mounted at /data:
# UPLOADS_DIR=/data/uploads
UPLOADS_DIR=./uploads

# Python logging verbosity for backend/app/main.py.
LOG_LEVEL=INFO

# Needed for the admin "recipe research" workspace (/recipe/research) — web
# search is only ever run after you explicitly approve a proposed query.
# Get a key at https://tavily.com. Without it, research chat still works but
# any search proposal you approve will fail with a clear error.
TAVILY_API_KEY=

# LiteLLM-format model string (provider/model-name) used by the research
# workspace (guided chat + auto-research) when a session hasn't picked its
# own model in the dropdown. Independent of ANTHROPIC_MODEL above, which
# stays in Anthropic-SDK format for the two flows that still call Anthropic
# directly (recipe generation/drafting, which use Anthropic's built-in
# server-executed web search — no multi-provider equivalent for that).
DEFAULT_MODEL=anthropic/claude-sonnet-5

# Optional — set either (or both) to unlock more choices in the research
# workspace's model dropdown. Only providers with a key present show up;
# Anthropic already works via ANTHROPIC_API_KEY above.
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional task-specific model defaults. These can also be changed from
# Workspace -> Models and are stored in SQLite.
# LLM_MODEL_FEEDBACK_MODERATION=gemini/gemini-2.5-flash-lite
# LLM_MODEL_DISH_NAME_EXTRACTION=gemini/gemini-2.5-flash-lite
# LLM_MODEL_RESEARCH_CHAT=gemini/gemini-2.5-flash
# LLM_MODEL_RESEARCH_PLAN=gemini/gemini-2.5-flash-lite
# LLM_MODEL_AUTO_RESEARCH_CREW=gemini/gemini-2.5-flash
# LLM_MODEL_SECTION_REFINE=gemini/gemini-2.5-flash
# LLM_MODEL_RECIPE_CUSTOMIZE=anthropic/claude-haiku-4-5-20251001
# LLM_MODEL_RECIPE_DRAFT=anthropic/claude-sonnet-5
# LLM_MODEL_GAP_GENERATION=anthropic/claude-sonnet-5
