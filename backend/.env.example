# Copy this file to .env and fill in your own key.
# Chat customization and recipe generation won't work without it —
# but the rest of the app (browsing seed recipes, nutrition facts,
# forking, review queue) works fine without a key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Set this to any secret string of your choosing. Enter the SAME value
# in the app's "Admin Token" field to unlock fork/save/review-approval.
# Anyone without this token gets read-only + session-only chat customization.
ADMIN_TOKEN=changeme
