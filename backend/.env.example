# Copy this file to .env and fill in your own key.
# Chat customization and recipe generation won't work without it —
# but the rest of the app (browsing seed recipes, nutrition facts,
# forking, review queue) works fine without a key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Set this to any secret string of your choosing. Enter the SAME value as
# the password on the app's /login page to unlock fork/save/review-approval.
# Anyone who doesn't log in gets read-only + session-only chat customization.
ADMIN_TOKEN=changeme

# Optional: separate key used to sign the admin session cookie. If unset,
# falls back to ADMIN_TOKEN (fine for local use) — set this explicitly if
# you want existing sessions to survive an ADMIN_TOKEN rotation.
SESSION_SECRET=

# Comma-separated list of frontend origins allowed to send credentialed
# requests (cookies). Defaults to the Next.js dev server if unset.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: override the local SQLite database path. Useful for tests,
# staging copies, or running multiple local instances.
DATABASE_URL=sqlite:///./curryforward.db

# Python logging verbosity for backend/app/main.py.
LOG_LEVEL=INFO

# Needed for the admin "recipe research" workspace (/recipe/research) — web
# search is only ever run after you explicitly approve a proposed query.
# Get a key at https://tavily.com. Without it, research chat still works but
# any search proposal you approve will fail with a clear error.
TAVILY_API_KEY=

# LiteLLM-format model string (provider/model-name) used by the research
# workspace (guided chat + auto-research) when a session hasn't picked its
# own model in the dropdown. Independent of ANTHROPIC_MODEL above, which
# stays in Anthropic-SDK format for the two flows that still call Anthropic
# directly (recipe generation/drafting, which use Anthropic's built-in
# server-executed web search — no multi-provider equivalent for that).
DEFAULT_MODEL=anthropic/claude-sonnet-5

# Optional — set either (or both) to unlock more choices in the research
# workspace's model dropdown. Only providers with a key present show up;
# Anthropic already works via ANTHROPIC_API_KEY above.
OPENAI_API_KEY=
GROQ_API_KEY=
