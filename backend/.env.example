# Copy this file to .env and fill in your own key.
# Chat customization and recipe generation won't work without it —
# but the rest of the app (browsing seed recipes, nutrition facts,
# forking, review queue) works fine without a key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Set this to any secret string of your choosing. Enter the SAME value as
# the password on the app's /login page to unlock fork/save/review-approval.
# Anyone who doesn't log in gets read-only + session-only chat customization.
ADMIN_TOKEN=changeme

# Optional: separate key used to sign the admin session cookie. If unset,
# falls back to ADMIN_TOKEN (fine for local use) — set this explicitly if
# you want existing sessions to survive an ADMIN_TOKEN rotation.
SESSION_SECRET=

# Comma-separated list of frontend origins allowed to send credentialed
# requests (cookies). Defaults to the Next.js dev server if unset.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
