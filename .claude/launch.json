{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd backend && source .venv/bin/activate && uvicorn app.main:app --reload --port 8000"
      ],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend-next && npm run dev"],
      "port": 3000
    }
  ]
}
